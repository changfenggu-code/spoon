{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sync-docs.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git add .claude-plugin/plugin.json .claude/settings.json CLAUDE.md README.md README-zh.md)",
      "Bash(git commit:*)"
    ]
  }
}
